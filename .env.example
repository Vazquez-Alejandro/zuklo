# Apify
APIFY_TOKEN=your_apify_token_here

# Redis (for BullMQ job queue)
REDIS_URL=redis://localhost:6379

# Puppeteer
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome

# Supabase (self-hosted local or cloud)
# For local Docker: run docker/supabase/setup.sh then docker/supabase/generate-keys.sh
NEXT_PUBLIC_SUPABASE_URL=http://localhost:9999
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Firebase Cloud Messaging
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project-id","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"}
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key_here
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe Prices (create these in your Stripe Dashboard)
STRIPE_PRICE_PREMIUM_MONTHLY=price_premium_monthly
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
